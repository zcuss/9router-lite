{
  "name": "9router-lite",
  "version": "0.4.73",
  "description": "9Router web dashboard",
  "scripts": {
    "predev": "node scripts/create-default-env.js",
    "dev": "node -e \"const { spawn } = require('child_process'); const args = ['next', 'dev', '--hostname', '0.0.0.0', '--webpack']; if (process.env.PORT) args.push('--port', process.env.PORT); const child = spawn(process.platform === 'win32' ? 'npx.cmd' : 'npx', args, { stdio: 'inherit' }); child.on('exit', code => process.exit(code ?? 0));\"",
    "build": "next build --webpack",
    "start": "next start",
    "dev:bun": "bun --bun next dev --hostname 0.0.0.0 --webpack --port 45231",
    "build:bun": "bun --bun next build --webpack",
    "start:bun": "bun ./.next/standalone/server.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@xyflow/react": "^12.10.1",
    "bcryptjs": "^3.0.3",
    "confbox": "^0.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "fs": "^0.0.1-security",
    "http-proxy-middleware": "^3.0.5",
    "jose": "^6.1.3",
    "marked": "^18.0.1",
    "material-symbols": "^0.44.6",
    "monaco-editor": "^0.55.1",
    "next": "^16.1.6",
    "next-intl": "^4.13.0",
    "node-forge": "^1.3.3",
    "node-machine-id": "^1.1.12",
    "open": "^11.0.0",
    "ora": "^9.1.0",
    "pg": "^8.16.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-is": "^16.13.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "selfsigned": "^5.5.0",
    "socks-proxy-agent": "^8.0.5",
    "sonner": "^2.0.7",
    "sql.js": "^1.14.1",
    "undici": "^7.19.2",
    "uuid": "^13.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.10"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.6.2"
  },
  "comment_better_sqlite3": "kept in optionalDependencies so npm install doesn't fail on systems without build tools — sql.js is used as fallback at runtime",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "19.2.17",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4"
  }
}
